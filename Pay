<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>WiPay Checkout</title>
    <style>
      :root {
        --bg: #eef4ff;
        --surface: #ffffff;
        --primary: #0d6efd;
        --primary-dark: #0b5ed7;
        --text: #212529;
        --muted: #6c757d;
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        background: linear-gradient(180deg, #eef4ff 0%, var(--bg) 100%);
        color: var(--text);
      }
      .container {
        width: min(900px, 96%);
        margin: 24px auto;
        padding: 20px;
      }
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 20px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: inherit;
      }
      .logo {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        overflow: hidden;
        display: grid;
        place-items: center;
        background: var(--primary);
      }
      .logo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }
      nav a {
        text-decoration: none;
        color: var(--primary);
        font-weight: 600;
      }
      .checkout-card {
        background: var(--surface);
        padding: 28px;
        border-radius: 18px;
        box-shadow: 0 20px 60px rgba(2, 6, 23, 0.06);
        max-width: 520px;
        margin: 0 auto;
        text-align: center;
      }
      h2 {
        margin: 0 0 16px;
      }
      .price {
        font-size: 2rem;
        color: #28a745;
        margin: 18px 0;
      }
      .customer-info {
        color: var(--muted);
        font-size: 0.95rem;
        margin: 4px 0;
      }
      .form-row {
        margin-top: 16px;
        text-align: left;
      }
      .form-row label {
        display: block;
        margin-bottom: 8px;
        font-weight: 700;
      }
      .form-row input,
      .form-row select {
        width: 100%;
        padding: 12px 14px;
        border-radius: 12px;
        border: 1px solid #d7dfe8;
        font-size: 1rem;
      }
      button {
        width: 100%;
        padding: 14px 16px;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 700;
        margin-top: 18px;
      }
      button:hover {
        background: var(--primary-dark);
      }
      .back-button {
        width: 100%;
        margin-top: 12px;
        background: #6c757d;
      }
      .success {
        display: none;
        margin-top: 18px;
        padding: 18px;
        background: #d4edda;
        color: #155724;
        border-radius: 14px;
      }
      footer {
        text-align: center;
        color: var(--muted);
        margin-top: 22px;
        font-size: 0.92rem;
      }
      .footer-links {
        display: flex;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
      }
      .footer-links a {
        color: var(--muted);
        text-decoration: none;
      }
      .footer-links a:hover {
        color: var(--primary);
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <a class="brand" href="Index.html">
          <div class="logo">
            <img src="images/shAn.png" alt="Shan Online Store logo" />
          </div>
          <div>
            <div style="font-weight:700">Shan Online Store</div>
            <div style="font-size:0.9rem; color:var(--muted);">Checkout</div>
          </div>
        </a>
        <nav>
          <a href="Index.html">Home</a>
          <a href="HTML.html">Store</a>
          <a href="delivery.html">Delivery</a>
          <a href="order-history.html">Order History</a>
        </nav>
      </header>
      <div class="checkout-card">
        <h2>WiPay Checkout</h2>
        <p id="customerName" class="customer-info">Customer: Guest</p>
        <p id="customerEmail" class="customer-info"></p>
        <div class="price" id="amount">JMD $0.00</div>
        <p id="productName" class="customer-info"></p>
        <form id="wipayForm" action="/checkout" method="POST">
          <input type="hidden" id="paymentAmount" name="amount" value="0" />
          <input type="hidden" id="paymentCustomer" name="customer" value="" />
          <input type="hidden" id="paymentEmail" name="email" value="" />
          <input type="hidden" id="paymentProduct" name="product" value="" />
          <button type="submit" id="payBtn">Pay with WiPay</button>
        </form>
        <button class="back-button" onclick="goBack()">← Back to Store</button>
        <div class="success" id="successMsg">
          <h3>✅ Payment Successful!</h3>
          <p>Your order has been processed.</p>
          <p>Redirecting back to the store...</p>
        </div>
      </div>
      <footer class="footer">
        <div>
          <a href="Index.html">Home</a> ·
          <a href="HTML.html">Store</a> ·
          <a href="order-history.html">Order History</a> ·
          <a href="Pay.html">Pay</a>
        </div>
        <div style="margin-top:6px;">Published 2026. Owner: Shanique.</div>
      </footer>
    </div>
    <script>
      function getQueryParam(param) {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get(param);
      }
      const amount = getQueryParam('amount') || '0.00';
      const customer = getQueryParam('customer') || 'Guest';
      const email = getQueryParam('email') || '';
      const product = getQueryParam('product') || 'Selected item';

      document.getElementById('amount').textContent = 'JMD $' + parseFloat(amount).toFixed(2);
      document.getElementById('customerName').textContent = 'Customer: ' + decodeURIComponent(customer);
      document.getElementById('customerEmail').textContent = email ? 'Email: ' + decodeURIComponent(email) : '';
      document.getElementById('productName').textContent = 'Product: ' + decodeURIComponent(product);
      document.getElementById('paymentAmount').value = amount;
      document.getElementById('paymentCustomer').value = customer;
      document.getElementById('paymentEmail').value = email;
      document.getElementById('paymentProduct').value = product;

      document.getElementById('wipayForm').addEventListener('submit', function (e) {
        e.preventDefault();
        document.getElementById('wipayForm').style.display = 'none';
        document.getElementById('successMsg').style.display = 'block';
        setTimeout(function () {
          window.location.href = 'HTML.html';
        }, 3000);
      });
      function goBack() {
        window.history.back();
      }
    </script>
  </body>
</html>

</script>

</body>
</html>

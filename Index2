<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shan Online Store</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f4f4f4;
}

header{
    background:#0d6efd;
    color:white;
    padding:15px 30px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

header a{
    color:white;
    text-decoration:none;
    font-weight:bold;
}

.container{
    width:90%;
    max-width:1200px;
    margin:auto;
    padding:20px;
}

.products{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.product{
    background:white;
    border-radius:10px;
    overflow:hidden;
    box-shadow:0 2px 10px rgba(0,0,0,.1);
}

.product img{
    width:100%;
    height:200px;
    object-fit:cover;
}

.product-content{
    padding:15px;
}

.product h3{
    margin-bottom:10px;
}

.price{
    color:green;
    font-size:20px;
    margin:10px 0;
}

button,
input[type="submit"]{
    background:#0d6efd;
    color:white;
    border:none;
    padding:10px 15px;
    cursor:pointer;
    border-radius:5px;
}

button:hover,
input[type="submit"]:hover{
    background:#0b5ed7;
}

.remove-button{
    background:#dc3545;
    margin-top:8px;
}

.remove-button:hover{
    background:#c82333;
}

section{
    margin-top:40px;
}

.cart-item{
    display:flex;
    justify-content:space-between;
    align-items:center;
    background:white;
    padding:10px;
    margin-bottom:10px;
    border-radius:8px;
}

.cart-item div{
    max-width:70%;
}

.cart-item small{
    color:#666;
}

.total{
    font-size:22px;
    font-weight:bold;
    margin-top:20px;
}

form{
    background:white;
    padding:20px;
    border-radius:10px;
}

input,textarea,select{
    width:100%;
    padding:10px;
    margin:10px 0;
    border:1px solid #ccc;
    border-radius:5px;
}

.confirmation,
.receipt-card{
    display:none;
    padding:20px;
    margin-top:20px;
    border-radius:10px;
}

.confirmation{
    background:#d4edda;
    color:#155724;
}

.receipt-card{
    background:white;
    color:#333;
    box-shadow:0 2px 10px rgba(0,0,0,.08);
}

.receipt-card button{
    margin-top:15px;
}

@media (max-width: 800px){
    header{
        flex-direction:column;
        align-items:flex-start;
        gap:10px;
    }
}

.product h3{
    margin-bottom:10px;
}

.price{
    color:green;
    font-size:20px;
    margin:10px 0;
}

button{
    background:#0d6efd;
    color:white;
    border:none;
    padding:10px 15px;
    cursor:pointer;
    border-radius:5px;
}

button:hover{
    background:#0b5ed7;
}

section{
    margin-top:40px;
}

.cart-item{
    display:flex;
    justify-content:space-between;
    background:white;
    padding:10px;
    margin-bottom:10px;
}

.total{
    font-size:22px;
    font-weight:bold;
    margin-top:20px;
}

form{
    background:white;
    padding:20px;
    border-radius:10px;
}

input,textarea{
    width:100%;
    padding:10px;
    margin:10px 0;
}

.confirmation{
    display:none;
    background:#d4edda;
    color:#155724;
    padding:20px;
    margin-top:20px;
    border-radius:10px;
}
</style>
</head>
<body>

<header>
<h2>Shan Online Store</h2>
<a href="#cart">🛒 Cart (<span id="cartCount">0</span>)</a>
</header>

<div class="container">

<section>

<h2>Products</h2>

<div class="products" id="productList"></div>

</section>

<section id="cart">

<h2>Shopping Cart</h2>

<div id="cartItems"></div>

<div class="total">
Total: $<span id="total">0.00</span>
</div>

</section>

<section>

<h2>Checkout</h2>

<form id="checkoutForm">

<input
type="text"
placeholder="Full Name"
required
>

<input
type="email"
placeholder="Email"
required
>

<textarea
placeholder="Delivery Address"
required></textarea>

<textarea
placeholder="Notes (Optional)"
></textarea>

<button type="submit">
Place Order
</button>

</form>

<div class="confirmation" id="confirmation">
<h2>✅ Thank You!</h2>
<p>Your order has been placed successfully.</p>
</div>

<div class="receipt-card" id="receipt">
    <h2>Order Receipt</h2>
    <pre id="receiptContent"></pre>
    <button id="emailReceiptButton">Email Receipt</button>
</div>

</section>

</div>

<script>
const products = [
    {
        name: "T-Shirt",
        price: 450.00,
        description: "Cotton, nylon, polyester.",
        image: "https://via.placeholder.com/400x250?text=Black+T-shirt"
    },
    {
        name: "Sweater",
        price: 600.00,
        description: "Thin or thick styles available.",
        image: "https://via.placeholder.com/400x250?text=Black+Sweater"
    },
    {
        name: "Caps",
        price: 350.00,
        description: "Water-resistant and stylish.",
        image: "https://via.placeholder.com/400x250?text=White+Cap"
    },
    {
        name: "Mugs and Plates",
        price: 350.00,
        description: "Ceramic mug set for hot drinks.",
        image: "https://via.placeholder.com/400x250?text=Mug+and+Plate+Set"
    }
];

let cart = [];

const productList = document.getElementById("productList");
const cartItems = document.getElementById("cartItems");
const total = document.getElementById("total");
const cartCount = document.getElementById("cartCount");
const confirmation = document.getElementById("confirmation");
const receipt = document.getElementById("receipt");
const receiptContent = document.getElementById("receiptContent");
const emailReceiptButton = document.getElementById("emailReceiptButton");

function displayProducts() {
    productList.innerHTML = "";

    products.forEach((product, index) => {
        productList.innerHTML += `
            <div class="product">
                <img src="${product.image}" alt="${product.name}">
                <div class="product-content">
                    <h3>${product.name}</h3>
                    <p>${product.description}</p>
                    <div class="price">$${product.price.toFixed(2)}</div>
                    <button onclick="addToCart(${index})">Add to Cart</button>
                </div>
            </div>
        `;
    });
}

function addToCart(index) {
    cart.push({ ...products[index], cartId: Date.now() + Math.random() });
    updateCart();
}

function removeFromCart(cartIndex) {
    cart.splice(cartIndex, 1);
    updateCart();
}

function updateCart() {
    cartItems.innerHTML = "";
    let sum = 0;

    if (cart.length === 0) {
        cartItems.innerHTML = "<p>Your cart is empty. Add an item to begin.</p>";
    } else {
        cart.forEach((item, index) => {
            sum += item.price;
            cartItems.innerHTML += `
                <div class="cart-item">
                    <div>
                        <strong>${item.name}</strong><br>
                        <small>${item.description}</small>
                    </div>
                    <div>
                        <span>$${item.price.toFixed(2)}</span><br>
                        <button class="remove-button" onclick="removeFromCart(${index})">Remove</button>
                    </div>
                </div>
            `;
        });
    }

    total.textContent = sum.toFixed(2);
    cartCount.textContent = cart.length;
}

function formatReceipt(name, email, address, notes, items, totalAmount) {
    const lines = [
        "Shan Online Store Receipt",
        "-------------------------",
        `Customer: ${name}`,
        `Email: ${email}`,
        `Delivery Address: ${address}`,
        "",
        "Items:",
        ...items.map(item => `- ${item.name}: $${item.price.toFixed(2)}`),
        "",
        `Notes: ${notes || 'None'}`,
        `Total: $${totalAmount.toFixed(2)}`
    ];
    return lines.join("\n");
}

function sendReceiptByEmail(email, subject, body) {
    const mailto = `mailto:${encodeURIComponent(email)}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = mailto;
}

const checkoutForm = document.getElementById("checkoutForm");
checkoutForm.addEventListener("submit", function(event) {
    event.preventDefault();

    if (cart.length === 0) {
        alert("Your cart is empty.");
        return;
    }

    const name = document.getElementById("customerName").value.trim();
    const email = document.getElementById("customerEmail").value.trim();
    const address = document.getElementById("customerAddress").value.trim();
    const notes = document.getElementById("orderNotes").value.trim();

    const totalAmount = cart.reduce((sum, item) => sum + item.price, 0);
    const receiptText = formatReceipt(name, email, address, notes, cart, totalAmount);

    receiptContent.textContent = receiptText;
    receipt.style.display = "block";
    confirmation.style.display = "block";

    emailReceiptButton.onclick = function() {
        sendReceiptByEmail(email, "Your Shan Online Store Receipt", receiptText);
    };

    cart = [];
    updateCart();
    checkoutForm.reset();
    window.scrollTo({ top: document.body.scrollHeight, behavior: "smooth" });
});

window.addEventListener("DOMContentLoaded", () => {
    displayProducts();
    updateCart();
});
</script>

</body>
</html>
